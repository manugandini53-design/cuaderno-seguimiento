{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Edit", "Write", "Read", "Glob", "Grep",
      "Bash(git status:*)", "Bash(git diff:*)", "Bash(git log:*)",
      "Bash(git add:*)", "Bash(git commit:*)", "Bash(git push)",
      "Bash(git pull:*)", "Bash(git tag:*)",
      "Bash(ls:*)", "Bash(cat:*)", "Bash(grep:*)", "Bash(node:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Read(./**/.env*)",
      "Read(./**/*secret*)",
      "Read(./**/*keystore*)"
    ]
  }
}
